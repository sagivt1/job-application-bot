# Which AI provider to use: gemini | openai | anthropic. Required — no default.
PROVIDER=gemini

TELEGRAM_BOT_TOKEN=
CHAT_ID=

AIRTABLE_TOKEN=
AIRTABLE_BASE=
AIRTABLE_TABLE=

# Only the selected provider's block needs filling in (the others can stay blank).

# Google / Gemini — used when PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Anthropic / Claude — used when PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (and any OpenAI-compatible endpoint) — used when PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional: point the OpenAI provider at any OpenAI-compatible endpoint.
# Leave blank for api.openai.com. For NVIDIA, set:
#   OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
#   OPENAI_API_KEY=<nvidia key>; OPENAI_MODEL=<e.g. nvidia/nemotron-3-ultra-550b-a55b>
OPENAI_BASE_URL=

# Optional: match-score cutoff (inclusive) at or above which a job triggers a
# cover letter + Telegram alert; everything below is logged to the CRM only.
# Default 80 — raise to be pickier, lower to catch more.
ALERT_THRESHOLD=80

# Optional: wall-clock cap (seconds) per job. Raise for slow local models
# (e.g. llama.cpp with few GPU layers), lower for fast hosted ones. Default 300.
JOB_TIMEOUT_SECONDS=300
